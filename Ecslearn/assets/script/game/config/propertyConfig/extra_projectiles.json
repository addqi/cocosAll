    { "id": "ExtraProjectiles-Value-Buff",   "value": 0, "tag": "add-buff" },
    { "id": "ExtraProjectiles-Value-Other",  "value": 0, "tag": "add-other" },
    { "id": "ExtraProjectiles-Mul-Buff",     "value": 0, "tag": "mul-buff" },
    { "id": "ExtraProjectiles-Mul-Other",    "value": 0, "tag": "mul-other" }
